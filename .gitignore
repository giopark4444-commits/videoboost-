# Entornos virtuales (uno por grupo de motores para evitar choques de dependencias)
.venv/
.venv-*/

# Binarios y modelos descargados por los instaladores
bin/
vendor/
models/

# Resultados
salidas/

# Presets de revelado guardados por el usuario (locales a cada instalación)
presets/

# Licencias: la privada JAMÁS se versiona; la activación es por máquina
clave_privada.pem
licencia.json

# Python
__pycache__/
*.pyc

# Sistema
.DS_Store
Thumbs.db

# Archivos de video/imagen de prueba
*.mp4
*.mkv
*.mov
*.avi
*.webm
